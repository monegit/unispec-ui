{
  "name": "@monegit/universal-ui",
  "version": "0.0.4",
  "description": "Building Reusable UI Components with ReactJS and React Native",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "import": "./dist/web.js",
      "require": "./dist/web.cjs"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "import": "./dist/native.js",
      "require": "./dist/native.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/web.ts src/native.ts --dts --format esm,cjs --clean --out-dir dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-native": "^0.74.0 || ^0.75.0 || ^0.76.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.18"
  }
}
